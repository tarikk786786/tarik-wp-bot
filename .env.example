# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Required in production. Generate a long random password; it protects the
# dashboard, API, QR codes, and live logs through HTTP Basic authentication.
ADMIN_TOKEN="replace_with_at_least_32_random_characters"

# Mount this path on persistent storage in production.
DATA_DIR="./data"
PORT="3000"
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# WA Anti-Ban Configuration
WA_MAX_MSG_PER_MINUTE="20"
WA_MAX_MSG_PER_HOUR="500"
WA_BASE_DELAY_MS="1500"
WA_RANDOM_DELAY_MS="2000"

# TG Anti-Ban Configuration
TG_MAX_MSG_PER_MINUTE="30"
TG_MAX_MSG_PER_HOUR="1000"
TG_BASE_DELAY_MS="1000"
TG_RANDOM_DELAY_MS="1500"

# Telegram user-client credentials from https://my.telegram.org
TG_API_ID=""
TG_API_HASH=""
